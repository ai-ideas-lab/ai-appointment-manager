{
  "name": "ai-appointment-manager",
  "version": "1.0.0",
  "description": "AI-powered multi-modal appointment management system",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "dev-frontend": "./dev-frontend.sh",
    "dev-all": "concurrently \"npm run dev\" \"npm run dev-frontend\"",
    "build-frontend": "cd frontend && npm run build",
    "install-all": "npm install && cd frontend && npm install"
  },
  "keywords": [
    "ai",
    "appointment",
    "calendar",
    "reminder",
    "productivity"
  ],
  "author": "ai-ideas-lab",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.6.0",
    "@types/express-validator": "^2.20.33",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "express-validator": "^7.3.1",
    "google-auth-library": "^9.2.0",
    "googleapis": "^128.0.0",
    "helmet": "^7.0.0",
    "ical": "^0.8.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.4",
    "openai": "^4.20.1",
    "redis": "^4.6.11",
    "winston": "^3.10.0",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.5.9",
    "@types/nodemailer": "^6.4.14",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "eslint": "^8.48.0",
    "jest": "^29.7.0",
    "prisma": "^5.6.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "tsx": "^3.12.7",
    "typescript": "^5.2.2"
  }
}
